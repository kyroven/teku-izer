import { Slider, HorizontalBox, VerticalBox } from "std-widgets.slint";
import { SlimSlider } from "edited-std-widgets/slider.slint";
import { Palette } from "palette.slint";
import "fonts/Orbitron-VariableFont_wght.ttf";
import "fonts/Orbitron-Bold.ttf";
import "fonts/Orbitron-ExtraBold.ttf";

component SeekBar {
    in-out property <int> current_time: 0;
    in property <int> total_duration;
    in property <bool> file_selected: false;
    in property <length> available_space: 350px;
    in property <string> font-family: "Orbitron";
    in property <int> resume_update_flag;

    callback seek(int);
    callback press();

    function format_time(time: int) -> string {
        let time_as_secs = (time / 1000).floor();
        let mins = (time_as_secs / 60).floor();
        let secs = (time_as_secs - (mins * 60));
        if secs < 10 {
            return "\{mins}:0\{secs}";
        }
        return "\{mins}:\{secs}";
    }

    changed current_time => {
        slider.value = self.current_time;
    }

    HorizontalLayout {
        spacing: 5px;
        
        current_label := Text {
            font-family: root.font-family;
            text: root.file_selected ? "\{root.format_time(root.current_time)}" : "--:--";
            color: Palette.accent-background;
        }

        slider := SlimSlider {
            fill: Palette.secondary-accent-background;
            minimum: 0.0;
            maximum: root.total_duration;
            width: clamp(root.available_space, 100px, 400px);
            value: root.current_time;
            changed => { root.press() }
            released(val) => { root.seek(val) }
        }

        total_label := Text {
            font-family: root.font-family;
            text: root.file_selected ? "\{root.format_time(root.total_duration)}" : "--:--";
            color: Palette.accent-background;
        }
    }
}

export component PlayBar inherits Rectangle {
    // background: #ABCCD2;
    background: #28373B;
    width: 800px;
    height: 60px;
    x: 0px;
    in property <string> font-family: "Orbitron";

    callback play_button();
    callback change_volume(float);
    callback seek_press();
    callback seek(int);

    in property <bool> playing;
    in property <bool> file_selected: false;
    in property <string> media_title: "NO SONG SELECTED";
    in property <string> media_artist: "-----------";

    in-out property <int> current_time: 0;
    in property <int> total_duration;
    in property <int> resume_update_flag;

    Text {
        text: parent.media_title;
        x: 15px;
        y: 15px;
        font-family: root.font-family;
        letter-spacing: 1px;
        color: parent.background.brighter(2.5);
    }

    Text {
        text: parent.media_artist;
        x: 15px;
        y: 30px;
        font-family: root.font-family;
        color: parent.background.brighter(2.5);
    }

    play_button := Rectangle {
        background: #28373B;
        width: (parent.height * 0.75);
        height: self.width;
        y: ((parent.height - self.height) / 2);
        border-radius: 25px;
        animate width { duration: 50ms; }

        states [
            hover when ta.has-hover && !ta.pressed : {
                play_button.width: (parent.height * 0.8);
            }
        ]

        HorizontalLayout {
            padding: 2px;
            Rectangle {
                background: root.file_selected ? Palette.secondary-accent-background : #6f898d;
                // width: (parent.height * 0.75);
                // height: (parent.height * 0.75);
                y: ((parent.height - self.height) / 2);
                border-radius: 25px;
                Image {
                    source: root.playing ? @image-url("icons/pause.svg") : @image-url("icons/play.svg");
                    colorize: #28373B;
                    width: (parent.height * 0.9);
                    height: (parent.height * 0.9);
                }
                ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.play_button();
                    }
                }
            }
        }
    }

    volume := HorizontalBox {
        x: 600px;
        SlimSlider {
            fill : Palette.secondary-accent-background;
            value: 1.0;
            maximum: 1.0;
            minimum: 0.0;
            width: 100px;
            changed(value) => {
                change_volume(value);
            }
        }
    }

    seekbar := SeekBar {
        current_time <=> root.current_time;
        total_duration: root.total_duration;
        file_selected: root.file_selected;
        resume_update_flag: root.resume_update_flag;

        font-family: root.font-family;
        x: ((parent.width / 2) - (self.width / 2));
        y: ((parent.height * 0.75) - (self.height / 2));
        press() => { root.seek_press() }
        seek(val) => { root.seek(val); }
    }
}

