component MenuBar inherits Rectangle {
    // background: #ABCCD2;
    background: @linear-gradient(180deg, #C5EAEC 0%, #819C9C 50%, #484F51 100%);
    width: 512px;
    height: 60px;
    x: 0px;
    y: 0px;

    callback file_button();
    
    HorizontalLayout {
        padding-left: 25px;
        padding-right: 25px;
        spacing: -5px;

        Rectangle {
            background: #28373B;
            width: (parent.height * 0.75);
            height: (parent.height * 0.75);
            y: ((parent.height - self.height) / 2);
            border-radius: 25px;

            HorizontalLayout {
                padding: 2px;
                Rectangle {
                    background: @linear-gradient(180deg, #A5CDD3 0%, #273537 50%, #202F30 100%);
                    // width: (parent.height * 0.75);
                    // height: (parent.height * 0.75);
                    y: ((parent.height - self.height) / 2);
                    border-radius: 25px;
                    Image {
                        source: @image-url("icons/home.svg");
                        colorize: @linear-gradient(180deg, #D2F6F7 0%, #B6D8D9 50%, #484F51 100%);
                        width: (parent.height * 0.9);
                        height: (parent.height * 0.9);
                    }
                }
            }
        }

        Rectangle {
            background: #28373B;
            height: (parent.height * 0.3);
            y: ((parent.height - self.height) / 2);
            width: 100px;
            z: -1.0;
        }

        Rectangle {
            background: #28373B;
            width: 200px;
            height: (parent.height * 0.75);
            y: ((parent.height - self.height) / 2);
            border-top-left-radius: (self.height / 2);
            border-bottom-left-radius: (self.height / 2);

            HorizontalLayout {
                padding: 2px;
                spacing: 2px;

                file := Rectangle {
                    background: @linear-gradient(180deg, #A5CDD3 0%, #273537 50%, #202F30 100%);
                    border-top-left-radius: (self.height / 2);
                    border-bottom-left-radius: (self.height / 2);
                    Text {
                        color: white;
                        text: "FILE";
                        font-weight: 700;
                    }
                    TouchArea {
                        clicked => {
                            root.file_button();
                        }
                    }
                }

                preferences := Rectangle {
                    background: @linear-gradient(180deg, #A5CDD3 0%, #273537 50%, #202F30 100%);
                    height: (parent.height * 0.95);
                    Text {
                        color: white;
                        text: "PREFERENCES";
                        font-weight: 700;
                    }
                }
            }
        }
    }

}

component PlayBar inherits Rectangle {
    // background: #ABCCD2;
    background: #28373B;
    width: 512px;
    height: 60px;
    x: 0px;

    callback play_button();

    Rectangle {
        background: #28373B;
        width: (parent.height * 0.75);
        height: (parent.height * 0.75);
        y: ((parent.height - self.height) / 2);
        border-radius: 25px;

        HorizontalLayout {
            padding: 2px;
            Rectangle {
                background: @linear-gradient(180deg, #A5CDD3 0%, #273537 50%, #202F30 100%);
                // width: (parent.height * 0.75);
                // height: (parent.height * 0.75);
                y: ((parent.height - self.height) / 2);
                border-radius: 25px;
                Image {
                    source: @image-url("icons/home.svg");
                    colorize: @linear-gradient(180deg, #D2F6F7 0%, #B6D8D9 50%, #484F51 100%);
                    width: (parent.height * 0.9);
                    height: (parent.height * 0.9);
                }
                TouchArea {
                    clicked => {
                        root.play_button();
                    }
                }
            }
        }
    }
}

