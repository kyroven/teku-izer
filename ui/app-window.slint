export component MainWindow inherits Window {
    width: 512px;
    height: 512px;
    default-font-family: "Orbitron";

    callback check_if_pair_solved();
    callback play_button();
    callback file_button();
    in property <bool> disable_tiles;

    MenuBar {
        width: parent.width;
        file_button => { root.file_button() }
    }

    PlayBar {
        width: parent.width;
        y: (parent.height - self.height);
        play_button => { root.play_button() }
    }

}